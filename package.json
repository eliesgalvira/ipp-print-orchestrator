{
  "name": "ipp-print-orchestrator",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "effect-language-service patch",
    "build": "tsc --build --pretty false",
    "typecheck": "tsc -p packages/shared/tsconfig.json --pretty false --noEmit && tsc -p packages/testkit/tsconfig.json --pretty false --noEmit && tsc -p apps/agent/tsconfig.json --pretty false --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "smoke:local": "bash scripts/smoke-test-local.sh",
    "smoke:pi": "bash scripts/smoke-test-pi.sh",
    "deploy:pi": "bash scripts/deploy-pi.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@effect/language-service": "^0.79.0",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^25.4.0",
    "effect-solutions": "^0.5.2",
    "fast-check": "^4.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
